# Docker Compose ports
FRONTEND_PORT=5173
BACKEND_PORT=8000
POSTGRES_DB=ykt_uslugi
POSTGRES_USER=ykt_uslugi
POSTGRES_PASSWORD=ykt_uslugi

# Use development locally. Set production only with a strong SECRET_KEY.
ENVIRONMENT=development
SECRET_KEY=replace-with-a-long-random-secret

ACCESS_TOKEN_EXPIRE_MINUTES=1440
SMS_CODE_TTL_SECONDS=300
SMS_RESEND_COOLDOWN_SECONDS=60
VERIFICATION_TOKEN_EXPIRE_MINUTES=15
